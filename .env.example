# Copy to .env and fill in. .env is gitignored and must never be committed.
#
# Vision extraction needs AT LEAST ONE provider. For a fully local, no-API-key
# setup leave the cloud keys blank and enable Ollama below.

# Optional — Gemini is the highest-quality extractor and leads the fallback chain.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional comma-separated fallback keys, tried in order when the primary is rate-limited (429).
GEMINI_FALLBACK_KEYS=

# Local-first — a local vision model via Ollama. No API key, no cost. Set ENABLED=true
# and `ollama pull` the model to run the whole pipeline offline.
# OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# Optional — LLM-as-auditor critic (enable with `review --audit`).
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — second-model self-consistency (enable with `review --cross-check`).
# MISTRAL_API_KEY=
# MISTRAL_FALLBACK_KEYS=

# Optional — ship pipeline traces to Langfuse (needs the `langfuse` extra).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Optional — WhatsApp Cloud API for the AR-collections agent + inbound webhook.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_API_VERSION=v21.0
